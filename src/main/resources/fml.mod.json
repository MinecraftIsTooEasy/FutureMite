{
  "schemaVersion": 1,
  "id": "futuremite",
  "version": "${version}",
  "depends": {
    "fishmodloader": ">=3.2.1"
  },
  "environment": "*",
  "name": "FutureMITE",
  "description": "",
  "authors": [
    "Fly6ird",
    "mgdcm",
    "AndrePraca"
  ],
  "entrypoints": {
    "preLaunch": [
      "com.github.fly6ird.futuremite.EarlyRiser"
    ],
    "main": [
      "com.github.fly6ird.futuremite.FutureMITEStart"
    ],
    "carryon": [
      "com.github.fly6ird.futuremite.compat.FutureMITECarryOnPlugin"
    ],
    "emi": [
      "com.github.fly6ird.futuremite.compat.FutureMITEEMIPlugin"
    ]
  },
  "mixins": [
    "futuremite.mixins.json"
  ],
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/RenderBlocks": [
        "com/github/fly6ird/futuremite/api/IRenderBlock"
      ]
    }
  },
  "accessWidener": "futuremite.accesswidener"
}